# ============================================================
# UniServe :: db-writer :: LOCAL (no Docker) environment
# Copy to .env.local for local dev: cp .env.local.example .env.local
# NEVER commit .env.local — it is gitignored.
# ============================================================

APP_ENV=development
TENANT_ID=t1
# DEBUG|INFO|WARN|ERROR — INFO (default) logs everything; set ERROR in prod.
LOG_LEVEL=INFO

# HTTP — standard Quarkus env-var mapping (quarkus.http.port -> QUARKUS_HTTP_PORT)
# NOTE: kept at 8090 (not 8081) to match the port this whole project already
# standardised on — see README.md "Ports" and docs/04_DB_WRITER_SERVICE.md's
# Phase 1 Implementation Notes. Docker mode and local mode use the same ports
# so nothing else needs to change when you flip RUN_MODE.
QUARKUS_HTTP_PORT=8090

# SQLite (WAL) database file — relative to services/db-writer/ (where
# scripts/dev-local.sh runs `mvn quarkus:dev` from). The directory must exist
# before Quarkus/SQLite will create the .db file in it (see data/.gitkeep).
DB_WRITER_DB_PATH=./data/uniserve-dev.db

# Pod-to-pod auth (Feature 04). Set to any non-empty value to require
# X-Internal-Key from api-gateway; leave empty (default) to disable in dev.
DB_WRITER_INTERNAL_API_KEY=local-dev-internal-key

# Backup (Feature 16) — the backup sidecar is Kubernetes-only; these are read
# by /api/v1/internal/backup/status but don't trigger a real backup locally.
BACKUP_DESTINATION=
BACKUP_INTERVAL_MINUTES=15

# NOTE: DB_WRITER_CACHE_MAX_SIZE / DB_WRITER_CACHE_TTL_MINUTES are NOT read by
# the current code (TicketCache.java hardcodes maximumSize=1000/TTL=2min) —
# omitted here rather than implying they do something they don't.
