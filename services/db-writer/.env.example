# ============================================================
# UniServe :: db-writer :: environment (Phase 1)
# Copy to .env for local dev. NEVER commit .env.
# Prefix: DB_WRITER_*
# ============================================================

# App
APP_ENV=development
TENANT_ID=t1
# DEBUG|INFO|WARN|ERROR — INFO (default) logs everything; set ERROR in prod.
LOG_LEVEL=INFO

# HTTP
DB_WRITER_HTTP_PORT=8090

# SQLite (WAL) database file location
DB_WRITER_DB_PATH=uniserve.db

# PHASE_2: PiiEncryptionService key material is configured here later.
