# ============================================================
# UniServe :: api-gateway :: environment (Phase 1)
# Copy to .env for local dev. NEVER commit .env.
# Prefix: GATEWAY_*
# ============================================================

# App
APP_ENV=development
TENANT_ID=default

# HTTP
GATEWAY_HTTP_PORT=8080

# Valkey event bus (Redis-compatible)
GATEWAY_VALKEY_URL=redis://localhost:6379

# Downstream services
AI_CORE_URL=http://localhost:8001
DB_WRITER_URL=http://localhost:8090

# Outbound mail (Phase 1 — wired fully in 14_NOTIFICATIONS)
GATEWAY_MAIL_FROM=noreply@uniserve.local

# Email adapter — IMAP inbound + SMTP outbound (Feature 02a)
# Leave EMAIL_IMAP_HOST empty in dev: polling is skipped, manual poll returns 0/0.
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=complaints@example.com
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_IMAP_POLL_INTERVAL=60s
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=complaints@example.com
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=complaints@uniserve.local

# WhatsApp adapter — Meta Business webhooks (Feature 02b)
WHATSAPP_VERIFY_TOKEN=dev-verify-token
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Dev data seeding (Features 02a/02b)
DEV_SEED_ENABLED=true

# JWT (wired fully in 11_MULTI_TENANCY)
JWT_SECRET=change-me-to-a-min-64-char-secret-change-me-to-a-min-64-char-secret
JWT_EXPIRY_ACCESS=15m
JWT_EXPIRY_REFRESH=7d
