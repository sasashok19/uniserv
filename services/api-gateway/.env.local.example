# ============================================================
# UniServe :: api-gateway :: LOCAL (no Docker) environment
# Copy to .env.local for local dev: cp .env.local.example .env.local
# NEVER commit .env.local — it is gitignored.
#
# These are the same variables application.properties already reads
# (${VAR:default} placeholders); scripts/dev-local.sh sources this file
# before starting the service, so plain env-var override is all that's
# needed — no code changes required to switch between Docker and local.
# ============================================================

APP_ENV=development
TENANT_ID=t1
# DEBUG|INFO|WARN|ERROR — INFO (default) logs everything; set ERROR in prod.
LOG_LEVEL=INFO

# HTTP — standard Quarkus env-var mapping (quarkus.http.port -> QUARKUS_HTTP_PORT)
QUARKUS_HTTP_PORT=8080

# Valkey (Redis-compatible) event bus — run via `valkey-server` / `redis-server`
# locally instead of the Docker container. Same port (6379) as Docker mode.
GATEWAY_VALKEY_URL=redis://localhost:6379

# Downstream services (talk to their locally-run ports, not Docker service names)
AI_CORE_URL=http://localhost:8001
DB_WRITER_URL=http://localhost:8090
# Shared pod-to-pod secret for db-writer's X-Internal-Key filter — must match
# DB_WRITER_INTERNAL_API_KEY on db-writer and ai-core's own .env.local too.
DB_WRITER_INTERNAL_API_KEY=local-dev-internal-key

# JWT auth (Feature 11)
JWT_SECRET=local-dev-secret-min-64-chars-change-in-production-never-use-this
JWT_EXPIRY_ACCESS=15m
JWT_EXPIRY_REFRESH=7d


# WhatsApp adapter (Feature 02b)
WHATSAPP_VERIFY_TOKEN=dev-verify-token
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Dev data seeding (Features 02a/02b)
DEV_SEED_ENABLED=true

# Email (Feature 02a) — a single Gmail App Password covers both directions.
# Generate one at Google Account > Security > 2-Step Verification > App
# passwords (needs 2FA enabled).

# Outbound: real send. EMAIL_SMTP_MOCK=true falls back to logging instead.
EMAIL_SMTP_MOCK=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-address@gmail.com
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=your-address@gmail.com
GATEWAY_MAIL_FROM=noreply@uniserve.local

# Inbound: IMAP polling (every EMAIL_IMAP_POLL_INTERVAL). EMAIL_IMAP_USER/
# PASSWORD default to EMAIL_SMTP_USER/PASSWORD above — only set these if the
# inbox you're reading differs from the one you send from.
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_IMAP_POLL_INTERVAL=60s
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
