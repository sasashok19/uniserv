# ============================================================
# UniServe :: ai-core :: environment (Phase 1)
# Copy to .env for local dev. NEVER commit .env.
# Prefix: AI_CORE_*
# ============================================================

# App
APP_ENV=development
TENANT_ID=default

# HTTP
AI_CORE_PORT=8001

# Event bus (Valkey, Redis-compatible) — Feature 01
VALKEY_URL=redis://localhost:6379
EVENT_BUS_MAX_RETRIES=3
EVENT_BUS_RETRY_DELAY_MS=1000
EVENT_BUS_CONSUMER_GROUP=uniserve

# Downstream
DB_WRITER_URL=http://localhost:8090
DB_WRITER_INTERNAL_API_KEY=

# Identity resolver (Feature 03)
IDENTITY_MERGE_CONFIDENCE_THRESHOLD=0.85
IDENTITY_PENDING_TIMEOUT_HOURS=48
IDENTITY_ANON_REF_PREFIX=ANON
DEFAULT_REGION=IN

# Conversation / LLM (Feature 06 — OpenAI Assistants API)
CONVERSATION_STATE_TTL_HOURS=2
AI_MAX_FOLLOWUP_QUESTIONS=2
DEFAULT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# asst_... id from `python scripts/create_assistant.py`; empty = rule-based fallback
OPENAI_ASSISTANT_ID=
OPENAI_MODEL=gpt-4o-mini
