# ============================================================
# UniServe :: ai-core :: environment (Phase 1)
# Copy to .env for local dev. NEVER commit .env.
# Prefix: AI_CORE_*
# ============================================================

# App
APP_ENV=development
TENANT_ID=default

# HTTP
AI_CORE_PORT=8001

# Event bus (Valkey, Redis-compatible)
VALKEY_URL=redis://localhost:6379

# Downstream
DB_WRITER_URL=http://localhost:8090

# Conversation / LLM (wired in 06_AI_CONVERSATION)
CONVERSATION_STATE_TTL_HOURS=2
AI_MAX_FOLLOWUP_QUESTIONS=2
DEFAULT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
