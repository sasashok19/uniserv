# ============================================================
# UniServe :: ai-core :: LOCAL (no Docker) environment
# Copy to .env.local for local dev: cp .env.local.example .env.local
# NEVER commit .env.local — it is gitignored.
#
# app/config.py loads (".env", ".env.local") in that order, so this file
# only needs to contain values that differ from (or don't yet exist in)
# .env — it does not need to duplicate everything.
# ============================================================

APP_ENV=development
AI_CORE_PORT=8001
# DEBUG|INFO|WARNING|ERROR|CRITICAL — INFO (default) logs everything; set
# ERROR in prod.
LOG_LEVEL=INFO

# Event bus — run via `valkey-server` / `redis-server` locally instead of the
# Docker container. Same port (6379) as Docker mode.
VALKEY_URL=redis://localhost:6379

# Downstream (talk to db-writer's/api-gateway's locally-run ports, not the
# Docker service names). API_GATEWAY_URL delivers ai.reply.send (identity
# requests, follow-ups) via api-gateway's email test-send endpoint.
DB_WRITER_URL=http://localhost:8090
DB_WRITER_INTERNAL_API_KEY=local-dev-internal-key
API_GATEWAY_URL=http://localhost:8080

# Conversation / LLM (Feature 06 — OpenAI Assistants API)
DEFAULT_LLM_PROVIDER=openai
# Leave blank here if services/ai-core/.env already has a working key — that
# file loads first and this one only overrides keys it actually sets.
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=

# PII scrubber (Feature 07)
PII_SCRUBBER_ENABLED=true
