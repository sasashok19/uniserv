# ============================================================
# UniServe :: shared environment reference (Phase 1)
# Each service also has its own .env.example with the variables it reads.
# ============================================================

# App
APP_ENV=development        # development | production
TENANT_ID=default

# Valkey event bus
VALKEY_URL=redis://valkey:6379

# Service URLs (in-cluster / compose names)
AI_CORE_URL=http://ai-core:8001
DB_WRITER_URL=http://db-writer:8090

# AI
DEFAULT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# JWT (wired in 11_MULTI_TENANCY)
JWT_SECRET=change-me-to-a-min-64-char-secret-change-me-to-a-min-64-char-secret
JWT_EXPIRY_ACCESS=15m
JWT_EXPIRY_REFRESH=7d
