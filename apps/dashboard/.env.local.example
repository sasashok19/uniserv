# ============================================================
# UniServe :: dashboard :: LOCAL (no Docker) environment
# Copy to .env.local for local dev: cp .env.local.example .env.local
# NEVER commit .env.local — it is gitignored.
#
# Next.js reads .env.local automatically — no code changes needed.
#
# NOTE: this project does not use NextAuth — there is no next-auth
# dependency and no NEXTAUTH_* variable is read anywhere in the app.
# Auth is a custom cookie set by app/api/auth/login/route.ts, which calls
# api-gateway directly. The variables below are the ones actually read
# (see apps/dashboard/.env.example and src/lib/gateway.ts).
# ============================================================

APP_ENV=development
NEXT_PUBLIC_TENANT_ID=t1

# api-gateway base URL — browser-facing (NEXT_PUBLIC_*) and server-side
# (route handlers / SSR) both point at the locally-run gateway here, so both
# vars are the same in local mode.
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080
API_GATEWAY_INTERNAL_URL=http://localhost:8080
